# Supabase Edge Functions – YouTube OAuth

# Required – Google OAuth (Web client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redirect URL that points back to this project function
# Example: https://YOUR-PROJECT-ID.functions.supabase.co/yt-oauth-callback
YT_REDIRECT_URI=https://qibjqqucmbrtuirysexl.functions.supabase.co/yt-oauth-callback

# Scopes (upload permission)
YT_SCOPES=https://www.googleapis.com/auth/youtube.upload

# Optional – Supabase (only needed if not available by default)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional – App URL to redirect after OAuth
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
EDGE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Authentication – configure Clerk OR Supabase JWT verification for Edge Functions
CLERK_ISSUER=
CLERK_JWKS_URL=
SUPABASE_JWT_SECRET=

# Optional – restrict diagnostics/admin-only Edge Functions to specific emails
EDGE_ADMIN_EMAILS=

# Notes
# - "access_type=offline" + "prompt=consent" ensure refresh_token on first consent
# - Store refresh_token server-side and use it to refresh access tokens
