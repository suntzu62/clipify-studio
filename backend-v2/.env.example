# ============================================
# CLIPIFY BACKEND V2 - Environment Variables
# ============================================

# Server
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:8080
RENDER_EXTERNAL_HOSTNAME=
DISABLE_WORKER=false
WORKER_CONCURRENCY=1
# Performance tuning (render/transcode)
# RENDER_PRESET: ultrafast | superfast | veryfast | fast | medium
RENDER_PRESET=superfast
# Number of clips rendered in parallel (recommended 2-4 for local dev)
RENDER_CONCURRENCY=4
# Threads per FFmpeg process (empty = auto)
RENDER_FFMPEG_THREADS=
# Faster detection mode for reframing/split (reduces sampling for speed)
RENDER_FAST_DETECTION=false
# Skip auto split-screen face detection entirely (faster, less smart split)
RENDER_SKIP_AUTO_SPLIT=false
# Disable loudnorm filter for faster renders
RENDER_DISABLE_AUDIO_NORMALIZATION=false
SOCIAL_MEDIA_ENABLED=false
UPLOADS_ENABLED=true
DIRECT_PUBLISHING_ENABLED=false
SCHEDULER_ENABLED=false
BRAND_KIT_ENABLED=false
LIVE_CLIPPING_ENABLED=false
# Optional: interval between rolling live windows in milliseconds
LIVE_INGEST_INTERVAL_MS=120000

# Beta gating (optional)
# When enabled and allowlist is non-empty, only listed emails can create jobs.
BETA_MODE=false
BETA_ALLOWLIST_EMAILS=

# Rate limiting (optional)
# Enabled by default in production. Disabled by default in development.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REGISTER_MAX=10
RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600
RATE_LIMIT_LOGIN_MAX=50
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_TEMP_CONFIG_MAX=60
RATE_LIMIT_TEMP_CONFIG_WINDOW_SECONDS=3600
RATE_LIMIT_JOB_START_MAX=20
RATE_LIMIT_JOB_START_WINDOW_SECONDS=3600

# ⚠️ SECURITY: Generate strong secrets for production
# Use: openssl rand -base64 32
API_KEY=GENERATE_RANDOM_32_CHARS_HERE
JWT_SECRET=GENERATE_RANDOM_32_CHARS_HERE
COOKIE_SECRET=GENERATE_RANDOM_32_CHARS_HERE

# Database (PostgreSQL via Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cortai_dev

# Supabase (ONLY for File Storage - auth is via PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=raw

# Local Storage (alternative to Supabase)
LOCAL_STORAGE_PATH=./uploads

# Redis (para jobs e cache)
# Use REDIS_URL in cloud environments (example: redis://default:pass@host:6379/0)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OpenAI (para Whisper transcrição)
OPENAI_API_KEY=sk-...

# Anthropic (opcional para análise de highlights)
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (opcional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# FFmpeg (opcional, usa ffmpeg-static se não definido)
FFMPEG_PATH=/usr/bin/ffmpeg

# YouTube API (opcional, para validação)
YOUTUBE_API_KEY=

# Mercado Pago (Pagamentos e Assinaturas)
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
# Em produção, use credenciais APP_USR-* (nunca TEST-*)
MERCADOPAGO_ACCESS_TOKEN=TEST-seu-access-token-aqui
MERCADOPAGO_PUBLIC_KEY=TEST-sua-public-key-aqui
MERCADOPAGO_WEBHOOK_SECRET=
# Força checkout sandbox quando true (em produção normalmente deve ser false)
MERCADOPAGO_SANDBOX_MODE=true

# Email notifications (opcional)
# Ative para enviar email quando jobs terminarem (success/failure).
NOTIFICATIONS_EMAIL_ENABLED=false
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-usuario-smtp
SMTP_PASS=sua-senha-smtp
SMTP_FROM=CortAI <no-reply@cortai.com.br>

# Development overrides (DO NOT USE IN PRODUCTION)
# Emails (comma-separated) that bypass usage limits while developing locally.
# Example: DEV_UNLIMITED_EMAILS=dev@yourdomain.com,another@yourdomain.com
DEV_UNLIMITED_EMAILS=

# Monitoring
SENTRY_DSN=

# Logs
LOG_LEVEL=info
