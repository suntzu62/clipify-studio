# ============================================
# CLIPIFY BACKEND V2 - Environment Variables
# ============================================

# Server
PORT=3001
NODE_ENV=development
API_KEY=your-secret-api-key-here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=raw

# Redis (para jobs e cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OpenAI (para Whisper transcrição)
OPENAI_API_KEY=sk-...

# Anthropic (para análise de highlights)
ANTHROPIC_API_KEY=sk-ant-...

# FFmpeg (opcional, usa ffmpeg-static se não definido)
FFMPEG_PATH=/usr/bin/ffmpeg

# YouTube API (opcional, para validação)
YOUTUBE_API_KEY=
# Cookies exportados do YouTube em base64 (Netscape cookies.txt)
YTDLP_COOKIES_B64=
# Alternativas suportadas pelo yt-dlp para alguns bloqueios do YouTube
YTDLP_VISITOR_DATA=
YTDLP_PO_TOKEN=
# Proxy residencial/mobile para o yt-dlp e ytdl-core
YTDLP_PROXY_URL=
# Serviço remoto de ingestão/download (opcional)
INGEST_SERVICE_URL=
INGEST_SERVICE_API_KEY=
INGEST_SERVICE_TIMEOUT_MS=300000
JOB_EXECUTION_MODE=auto

# Worker/queue tuning (importante para Render/instâncias pequenas)
WORKER_CONCURRENCY=1
WORKER_LOCK_DURATION_MS=900000
WORKER_STALLED_INTERVAL_MS=30000
WORKER_MAX_STALLED_COUNT=3

# Render tuning
RENDER_SMART_CROP=false
RENDER_BATCH_CONCURRENCY=1
RENDER_FFMPEG_THREADS=2

# Logs
LOG_LEVEL=info

# Billing
# Optional: user with unlimited access (does not consume quotas)
UNLIMITED_ADMIN_EMAIL=gabrielfootze@gmail.com
