{
  "name": "clipify-backend-v2",
  "version": "2.0.0",
  "description": "Backend simplificado e confiável para ClipifyStudio",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --exclude \"**/*-player-script.js\" src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "start:api": "DISABLE_WORKER=true node dist/index.js",
    "start:worker": "node dist/jobs/worker.js",
    "typecheck": "tsc --noEmit",
    "download-models": "node scripts/download-models.js",
    "postinstall": "node scripts/download-models.js || echo 'Warning: Failed to download face detection models'; npm rebuild canvas --build-from-source || echo 'Warning: Failed to rebuild canvas from source'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "video",
    "clips",
    "ai",
    "youtube"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@distube/ytdl-core": "^4.14.4",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/websocket": "^8.3.1",
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^10.38.0",
    "@supabase/supabase-js": "^2.39.0",
    "@tensorflow/tfjs-node": "^4.11.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.15.6",
    "@vladmandic/face-api": "^1.7.13",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.4.0",
    "canvas": "^2.11.2",
    "dotenv": "^16.4.1",
    "execa": "^8.0.1",
    "fastify": "^4.26.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.12.0",
    "nodemailer": "^6.10.1",
    "openai": "^4.104.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "sharp": "^0.33.2",
    "youtube-dl-exec": "^2.4.17",
    "yt-dlp-wrap": "^2.3.12",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.16",
    "@types/nodemailer": "^6.4.22",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "@ybd-project/ytdl-core": "^6.0.8",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": "20.x"
  }
}
